{
  "routes": [
    {
      "route": "/.auth/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/*",
      "allowedRoles": []
    }
  ],
  "responseOverrides": {
    "401": {
      "rewrite": "/403.html",
      "statusCode": 403
    },
    "403": {
      "rewrite": "/403.html",
      "statusCode": 403
    }
  }
}
