{
  "routes": [
    {
      "route": "/",
      "allowedRoles": ["none"]
    },
    {
      "route": "/index.html",
      "allowedRoles": ["none"]
    }
  ],
  "responseOverrides": {
    "401": {
      "rewrite": "/403.html",
      "statusCode": 403
    },
    "403": {
      "rewrite": "/403.html",
      "statusCode": 403
    }
  }
}
